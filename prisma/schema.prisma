// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Management
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user") // user, admin
  country       String?   @default("US")
  preferredCurrency String @default("USD")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  payments      Payment[]
  brands        Brand[]
  scripts       Script[]
  frameworks    Framework[]
  contentPlans  ContentPlan[]
  usage         Usage[]
  
  // Team Management (Agency plan)
  ownedTeams        Team[]           @relation("TeamOwner")
  teamMemberships   TeamMember[]
  sentInvitations   TeamInvitation[] @relation("InvitationSender")
  receivedInvitations TeamInvitation[] @relation("InvitationReceiver")
  
  // Support System
  supportTickets    SupportTicket[]  @relation("TicketCreator")
  assignedTickets   SupportTicket[]  @relation("TicketAssignee")
  ticketMessages    TicketMessage[]
  userSessions      UserSession[]
  
  // Flagged signups (if this user was flagged)
  flaggedSignups    FlaggedSignup[]
  
  // Referral System
  referralCode      String?          @unique
  referredBy        String?
  referrer          User?            @relation("Referrals", fields: [referredBy], references: [id], onDelete: SetNull)
  referrals         User[]           @relation("Referrals")
  referralRewards   ReferralReward[]
  
  // Referral tracking (as referrer)
  sentReferrals     Referral[]       @relation("ReferrerUser")
  // Referral tracking (as referred)
  receivedReferrals Referral[]       @relation("ReferredUser")
  
  // Discount tracking
  hasLifetimeDiscount Boolean @default(false)
  lifetimeDiscountPercent Int @default(0)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Subscription & Payments
model Subscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId         String // starter, pro, agency
  status         String @default("active") // active, cancelled, expired, paused
  paymentGateway String // paddle, sslcommerz, bkash, nagad

  // Paddle specific
  paddleSubscriptionId String?
  paddleCustomerId     String?

  // Local gateway specific
  transactionId String?
  paymentMethod String? // bkash, nagad, rocket, card

  // Common fields
  amount        Decimal
  currency      String // USD, BDT
  billingCycle  String @default("monthly") // monthly, yearly

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  nextBillingDate    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]

  @@index([userId])
}

model Payment {
  id             String  @id @default(cuid())
  userId         String
  subscriptionId String?
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  amount   Decimal
  currency String @default("BDT")

  // Plan info (for manual payment before subscription activation)
  planId   String?
  planName String?
  billing  String? // monthly, yearly

  paymentGateway      String
  gatewayTransactionId String?
  
  // Manual payment verification
  transactionId String? // User-provided TRX ID
  phoneNumber   String? // User's bKash number
  email         String? // User's email for confirmation
  method        String? // bkash, nagad, rocket
  verifiedBy    String? // Admin user ID who verified
  verifiedAt    DateTime?

  status String @default("pending") // pending, verified, rejected, success, failed, refunded

  metadata Json? // Store gateway-specific data

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([transactionId])
}

// Brand Brain
model Brand {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  industry    String?
  niche       String?
  description String?

  // Brand Voice & Personality
  mission    String?
  vision     String?
  usp        String?
  tagline    String?
  tone       String[] // friendly, luxury, premium, funny, professional
  voice      String?  @db.Text
  writingStyle String? @db.Text

  // Audience & Market
  targetAudience String?  @db.Text
  painPoints     String[] // Array of pain points
  keywords       String[]
  competitors    String[]

  // Brand Rules
  forbiddenWords String[]
  preferredWords String[]
  brandColors    String[]

  // Documents & Assets
  documents Json? // Store uploaded document references
  assets Json? // Store uploaded asset references (logos, images, videos)
  templates Json? // Store brand templates (caption, hook, cta, content)
  voiceProfile Json? // AI-learned brand voice profile

  // Agency Mode
  isClientBrand Boolean @default(false) // Is this brand managed for a client?
  clientName    String? // Client's name
  clientEmail   String? // Client's email
  clientCompany String? // Client's company name
  accessLevel   String? // Client's access level: view, comment, edit

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scripts      Script[]
  contentPlans ContentPlan[]

  @@index([userId])
}

// AI Content Writer & Script Library
model Script {
  id      String @id @default(cuid())
  userId  String
  brandId String?
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  title       String
  type        String // reel, carousel, story, post, ad, hook, ovc
  platform    String // facebook, instagram, tiktok, youtube, linkedin
  framework   String? // AIDA, PAS, BAB, etc.

  // Content
  hook        String?  @db.Text
  body        String?  @db.Text
  cta         String?
  caption     String?  @db.Text
  hashtags    String[]
  voiceOver   String?  @db.Text
  screenText  String[] // Text overlays for video
  bRoll       String[] // B-roll suggestions

  // OVC Director specific
  scenes Json? // Array of scene objects

  // Metadata
  duration    Int? // in seconds
  goal        String? // sales, leads, awareness
  tone        String?
  language    String @default("en")

  // Organization
  tags        String[]
  folder      String?
  isFavorite  Boolean  @default(false)

  // Performance
  viralScore  Int? // 0-100

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([brandId])
  @@index([type])
  @@index([platform])
}

// Framework Brain
model Framework {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  category    String // copywriting, storytelling, hooks, swipe_files
  
  content     String  @db.Text
  examples    String[] // Array of examples
  
  // Vector embeddings for semantic search (store as JSON)
  embeddings  Json?

  source      String? // alex_hormozi, russell_brunson, etc.
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([category])
}

// Content Planner
model ContentPlan {
  id      String @id @default(cuid())
  userId  String
  brandId String?
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  name            String
  duration        Int    @default(30) // days
  platform        String[] // facebook, instagram, etc.
  goal            String // sales, leads, awareness
  postingFrequency Int    @default(1) // posts per day

  // Content strategy
  contentStyle String[] // educational, entertaining, promotional
  season       String?
  specialEvent String?

  // Generated plan
  plan Json // Array of daily content with ideas, hooks, CTAs

  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([brandId])
}

// Usage Tracking
model Usage {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  month       Int // 1-12
  year        Int
  
  scriptsGenerated    Int @default(0)
  hooksGenerated      Int @default(0)
  contentPlansCreated Int @default(0)
  ovcScenesGenerated  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month, year])
  @@index([userId])
}

// Pricing Plans (Reference data)
model PricingPlan {
  id String @id // starter, pro, agency

  name        String
  description String?

  // Pricing
  priceUsd Decimal
  priceBdt Decimal
  priceEur Decimal?

  // Paddle price IDs
  paddlePriceIdMonthlyUsd String?
  paddlePriceIdMonthlyEur String?

  // Features & Limits
  features Json // Array of feature strings
  limits   Json // { scriptsPerMonth: 100, brandProfiles: 1, etc. }

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Team Management (Agency Plan)
model Team {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  name        String
  description String?
  avatar      String? // Team logo/avatar URL

  // Settings
  maxMembers Int @default(5) // Based on plan
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     TeamMember[]
  invitations TeamInvitation[]

  @@index([ownerId])
}

model TeamMember {
  id       String @id @default(cuid())
  teamId   String
  userId   String
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role String // admin, member, creator
  
  // Permissions (for granular access control)
  canManageTeam    Boolean @default(false) // Can invite/remove members, change settings
  canManageBrands  Boolean @default(true)  // Can create/edit brands
  canCreateContent Boolean @default(true)  // Can generate scripts/hooks/plans
  canViewAnalytics Boolean @default(true)  // Can view team analytics

  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model TeamInvitation {
  id       String @id @default(cuid())
  teamId   String
  senderId String
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sender   User   @relation("InvitationSender", fields: [senderId], references: [id], onDelete: Cascade)

  // Invitation details
  email       String
  role        String // admin, member, creator
  token       String @unique @default(cuid())
  
  // Receiver (if user already exists)
  receiverId  String?
  receiver    User?   @relation("InvitationReceiver", fields: [receiverId], references: [id], onDelete: SetNull)

  // Status
  status      String   @default("pending") // pending, accepted, declined, expired
  expiresAt   DateTime
  respondedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId])
  @@index([email])
  @@index([token])
  @@index([status])
}

// Session Tracking (for admin monitoring)
model UserSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Session info
  sessionId   String   @unique
  ipAddress   String?
  userAgent   String?
  country     String?
  city        String?
  device      String?
  browser     String?
  os          String?

  // Activity
  currentPage String?
  lastActivity DateTime @default(now())
  
  // Status
  isActive    Boolean  @default(true)
  startedAt   DateTime @default(now())
  endedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([sessionId])
  @@index([isActive])
}

// Live Support System
model SupportTicket {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation("TicketCreator", fields: [userId], references: [id], onDelete: Cascade)
  
  // Ticket details
  subject     String
  description String  @db.Text
  priority    String  @default("medium") // low, medium, high, critical
  category    String? // technical, billing, feature_request, bug, other
  
  // Status
  status      String  @default("open") // open, in_progress, waiting, resolved, closed
  
  // Assignment
  assignedToId String?
  assignedTo   User?   @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedAt   DateTime?
  
  // Resolution
  resolvedAt  DateTime?
  closedAt    DateTime?
  
  // Metadata
  userAgent   String?
  ipAddress   String?
  sessionId   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages TicketMessage[]

  @@index([userId])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
}

model TicketMessage {
  id       String        @id @default(cuid())
  ticketId String
  userId   String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  message     String  @db.Text
  isInternal  Boolean @default(false) // Internal notes only visible to admins
  isAdminReply Boolean @default(false) // Is this from admin?
  
  // Attachments
  attachments Json? // Array of file URLs

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticketId])
  @@index([userId])
}

// Referral Program
model ReferralReward {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Reward details
  type        String // bonus_generations, free_month, lifetime_discount
  description String
  amount      Int    // Generations count or months
  
  // Bonus generations tracking
  generationsTotal     Int @default(0) // Total bonus generations awarded
  generationsUsed      Int @default(0) // How many used
  generationsRemaining Int @default(0) // Remaining
  
  // Status
  status      String   @default("active") // active, used, expired
  expiresAt   DateTime? // For bonus generations (6 months)
  appliedAt   DateTime? // When reward was applied
  
  // Source
  referralCount Int @default(0) // Number of paid referrals to earn this (1, 3, 5, 10, 25)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
}

model Referral {
  id            String @id @default(cuid())
  referrerId    String // User who sent the invite
  referredUserId String // User who signed up
  
  referrer User @relation("ReferrerUser", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  
  // Tracking
  status         String   @default("pending") // pending, paid, rewarded, expired, invalid
  ipAddress      String?
  userAgent      String?
  
  // Payment tracking
  firstPaidAt    DateTime? // When referred user made first payment
  rewardGivenAt  DateTime? // When referrer got reward
  
  // Anti-abuse
  paymentMethod  String? // To detect same payment method
  isValid        Boolean  @default(true) // Can be invalidated if abuse detected
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([referrerId, referredUserId]) // Prevent duplicate referrals
  @@index([referrerId])
  @@index([referredUserId])
  @@index([status])
}



// Device Fingerprinting (Trial Abuse Prevention)
model DeviceFingerprint {
  id          String   @id @default(cuid())
  fingerprint String   @unique // Browser fingerprint ID
  
  // First seen
  firstSeenIp       String?
  firstSeenEmail    String?
  firstSeenAt       DateTime @default(now())
  
  // Associated users (for detecting multiple accounts)
  userIds      String[] // Array of user IDs from this device
  emailAddresses String[] // All emails used from this device
  ipAddresses    String[] // All IPs seen with this device
  
  // Metadata
  userAgent    String?
  browser      String?
  os           String?
  device       String?
  screenSize   String?
  timezone     String?
  language     String?
  
  // Risk assessment
  riskLevel    String @default("low") // low, medium, high
  isBlocked    Boolean @default(false)
  blockedAt    DateTime?
  blockedReason String?
  
  // Tracking
  signupCount  Int @default(0) // How many signups from this device
  lastSeenAt   DateTime @default(now())
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fingerprint])
  @@index([riskLevel])
  @@index([isBlocked])
}

// Flagged Signups (Admin Review System)
model FlaggedSignup {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Detection details
  email       String
  ipAddress   String?
  riskLevel   String  // low, medium, high
  flags       String[] // Array of detected issues
  reason      String?  @db.Text
  metadata    Json?    // Additional detection data
  
  // Admin decision
  status         String   @default("pending") // pending, approved, rejected, blocked
  reviewedBy     String?  // Admin user ID who reviewed
  reviewedAt     DateTime?
  reviewNotes    String?  @db.Text
  adminDecision  String?  // allow, block, monitor
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([riskLevel])
  @@index([createdAt])
}
