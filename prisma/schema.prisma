// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Management
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user") // user, admin
  country       String?   @default("US")
  preferredCurrency String @default("USD")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  payments      Payment[]
  brands        Brand[]
  scripts       Script[]
  frameworks    Framework[]
  contentPlans  ContentPlan[]
  usage         Usage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Subscription & Payments
model Subscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId         String // starter, pro, agency
  status         String @default("active") // active, cancelled, expired, paused
  paymentGateway String // paddle, sslcommerz, bkash, nagad

  // Paddle specific
  paddleSubscriptionId String?
  paddleCustomerId     String?

  // Local gateway specific
  transactionId String?
  paymentMethod String? // bkash, nagad, rocket, card

  // Common fields
  amount        Decimal
  currency      String // USD, BDT
  billingCycle  String @default("monthly") // monthly, yearly

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  nextBillingDate    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]

  @@index([userId])
}

model Payment {
  id             String  @id @default(cuid())
  userId         String
  subscriptionId String?
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  amount   Decimal
  currency String

  paymentGateway      String
  gatewayTransactionId String?

  status String @default("pending") // success, failed, pending, refunded

  // For local payments
  paymentMethod String?
  phoneNumber   String?

  metadata Json? // Store gateway-specific data

  paidAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([subscriptionId])
}

// Brand Brain
model Brand {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  industry    String?
  niche       String?
  description String?

  // Brand Voice & Personality
  mission    String?
  vision     String?
  usp        String?
  tagline    String?
  tone       String[] // friendly, luxury, premium, funny, professional
  voice      String?  @db.Text
  writingStyle String? @db.Text

  // Audience & Market
  targetAudience String?  @db.Text
  painPoints     String[] // Array of pain points
  keywords       String[]
  competitors    String[]

  // Brand Rules
  forbiddenWords String[]
  preferredWords String[]
  brandColors    String[]

  // Documents & Assets
  documents Json? // Store uploaded document references
  assets Json? // Store uploaded asset references (logos, images, videos)
  templates Json? // Store brand templates (caption, hook, cta, content)
  voiceProfile Json? // AI-learned brand voice profile

  // Agency Mode
  isClientBrand Boolean @default(false) // Is this brand managed for a client?
  clientName    String? // Client's name
  clientEmail   String? // Client's email
  clientCompany String? // Client's company name
  accessLevel   String? // Client's access level: view, comment, edit

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scripts      Script[]
  contentPlans ContentPlan[]

  @@index([userId])
}

// AI Content Writer & Script Library
model Script {
  id      String @id @default(cuid())
  userId  String
  brandId String?
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  title       String
  type        String // reel, carousel, story, post, ad, hook, ovc
  platform    String // facebook, instagram, tiktok, youtube, linkedin
  framework   String? // AIDA, PAS, BAB, etc.

  // Content
  hook        String?  @db.Text
  body        String?  @db.Text
  cta         String?
  caption     String?  @db.Text
  hashtags    String[]
  voiceOver   String?  @db.Text
  screenText  String[] // Text overlays for video
  bRoll       String[] // B-roll suggestions

  // OVC Director specific
  scenes Json? // Array of scene objects

  // Metadata
  duration    Int? // in seconds
  goal        String? // sales, leads, awareness
  tone        String?
  language    String @default("en")

  // Organization
  tags        String[]
  folder      String?
  isFavorite  Boolean  @default(false)

  // Performance
  viralScore  Int? // 0-100

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([brandId])
  @@index([type])
  @@index([platform])
}

// Framework Brain
model Framework {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  category    String // copywriting, storytelling, hooks, swipe_files
  
  content     String  @db.Text
  examples    String[] // Array of examples
  
  // Vector embeddings for semantic search (store as JSON)
  embeddings  Json?

  source      String? // alex_hormozi, russell_brunson, etc.
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([category])
}

// Content Planner
model ContentPlan {
  id      String @id @default(cuid())
  userId  String
  brandId String?
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  name            String
  duration        Int    @default(30) // days
  platform        String[] // facebook, instagram, etc.
  goal            String // sales, leads, awareness
  postingFrequency Int    @default(1) // posts per day

  // Content strategy
  contentStyle String[] // educational, entertaining, promotional
  season       String?
  specialEvent String?

  // Generated plan
  plan Json // Array of daily content with ideas, hooks, CTAs

  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([brandId])
}

// Usage Tracking
model Usage {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  month       Int // 1-12
  year        Int
  
  scriptsGenerated    Int @default(0)
  hooksGenerated      Int @default(0)
  contentPlansCreated Int @default(0)
  ovcScenesGenerated  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month, year])
  @@index([userId])
}

// Pricing Plans (Reference data)
model PricingPlan {
  id String @id // starter, pro, agency

  name        String
  description String?

  // Pricing
  priceUsd Decimal
  priceBdt Decimal
  priceEur Decimal?

  // Paddle price IDs
  paddlePriceIdMonthlyUsd String?
  paddlePriceIdMonthlyEur String?

  // Features & Limits
  features Json // Array of feature strings
  limits   Json // { scriptsPerMonth: 100, brandProfiles: 1, etc. }

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
